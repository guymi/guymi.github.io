---
import { SITE } from "@lib/site";

const links = [
  { href: SITE.social.github, label: "GitHub", id: "github", external: true },
  { href: SITE.social.linkedin, label: "LinkedIn", id: "linkedin", external: true },
  { href: SITE.social.rss, label: "RSS", id: "rss", external: false },
];
---

<ul class="social-links" role="list">
  {links.map((link) => (
    <li>
      <a
        href={link.href}
        aria-label={link.label}
        rel={link.external ? "me noopener noreferrer" : "alternate"}
        target={link.external ? "_blank" : undefined}
        class={`${link.id}-icon`}
      >
        {link.id === "github" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 1.5c-5.53 0-10 4.52-10 10.1 0 4.46 2.87 8.24 6.84 9.58.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.7-2.78.61-3.37-1.36-3.37-1.36-.45-1.18-1.11-1.5-1.11-1.5-.9-.62.07-.61.07-.61 1 .07 1.53 1.04 1.53 1.04.89 1.54 2.34 1.09 2.91.83.09-.66.35-1.09.64-1.34-2.22-.26-4.55-1.13-4.55-5 0-1.11.39-2.01 1.03-2.72-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.04a9.27 9.27 0 0 1 5 0c1.9-1.31 2.74-1.04 2.74-1.04.56 1.41.21 2.45.1 2.71.64.71 1.03 1.61 1.03 2.72 0 3.88-2.34 4.74-4.57 5 .36.32.69.94.69 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49 3.96-1.34 6.83-5.12 6.83-9.58 0-5.58-4.47-10.1-10-10.1Z" />
          </svg>
        )}
        {link.id === "linkedin" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.98 3.5a2.49 2.49 0 1 1 0 4.98 2.49 2.49 0 0 1 0-4.98ZM2.4 9h5.17v12.5H2.4V9Zm7.67 0h4.95v1.71h.07c.69-1.24 2.37-2.54 4.87-2.54 5.21 0 6.17 3.43 6.17 7.89V21.5h-5.16v-6.89c0-1.64-.03-3.75-2.29-3.75-2.3 0-2.65 1.79-2.65 3.63V21.5H10.1V9Z" />
          </svg>
        )}
        {link.id === "rss" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 16a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-4-7a1 1 0 0 1 1-1c10.48 0 19 8.52 19 19a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1c0-7.18-5.82-13-13-13a1 1 0 0 1-1-1V9Zm0-6a1 1 0 0 1 1-1C13.6 2 22 10.4 22 21a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1c0-7.72-6.28-14-14-14a1 1 0 0 1-1-1V3Z" />
          </svg>
        )}
      </a>
    </li>
  ))}
</ul>
