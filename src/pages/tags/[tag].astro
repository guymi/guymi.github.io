---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";
import { getPosts, getAllTags } from "@lib/posts";

export async function getStaticPaths() {
  const tags = [...(await getAllTags()).keys()];
  const posts = await getPosts();
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => (p.data.tags ?? []).includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Posts tagged "${tag}".`}>
  <div class="wrap">
    <h1 style="margin-top:3rem;">#{tag}</h1>
    <p class="post-meta">{posts.length} post{posts.length === 1 ? "" : "s"}</p>
    <div class="rail">
      {posts.map((p) => <PostCard post={p} />)}
    </div>
  </div>
</BaseLayout>
