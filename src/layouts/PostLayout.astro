        'FinOps': { full: 'Cloud Financial Management', url: 'https://www.finops.org/' },
        'DNSSEC': { full: 'Domain Name System Security Extensions', url: 'https://en.wikipedia.org/wiki/Domain_Name_System_Security_Extensions' },
        'DNSKEY': { full: 'DNSSEC public key record', url: 'https://www.rfc-editor.org/rfc/rfc4034' },
        'RRSIG': { full: 'DNSSEC signature record', url: 'https://www.rfc-editor.org/rfc/rfc4034' },
        'NSEC3': { full: 'Authenticated denial of existence record (hashed)', url: 'https://www.rfc-editor.org/rfc/rfc5155' },
        'NSEC': { full: 'Authenticated denial of existence record', url: 'https://www.rfc-editor.org/rfc/rfc4034' },
        'NXDOMAIN': { full: 'DNS response code for non-existent domain name', url: 'https://www.rfc-editor.org/rfc/rfc1035' },
        'DoH': { full: 'DNS over HTTPS', url: 'https://www.rfc-editor.org/rfc/rfc8484' },
        'DoT': { full: 'DNS over TLS', url: 'https://www.rfc-editor.org/rfc/rfc7858' },
        'CAA': { full: 'Certification Authority Authorization record (DNS)', url: 'https://www.rfc-editor.org/rfc/rfc6844' },
        'TTL': { full: 'Time To Live (DNS cache lifetime)', url: 'https://en.wikipedia.org/wiki/Time_to_live' },
        'SOA': { full: 'Start of Authority record (DNS)', url: 'https://en.wikipedia.org/wiki/SOA_record' },
        'NS': { full: 'Name Server record (DNS)', url: 'https://en.wikipedia.org/wiki/List_of_DNS_record_types#NS' },
        'MX': { full: 'Mail Exchange record (DNS)', url: 'https://en.wikipedia.org/wiki/MX_record' },
        'TXT': { full: 'Text record (DNS)', url: 'https://en.wikipedia.org/wiki/TXT_record' },
        'AAAA': { full: 'IPv6 address record (DNS)', url: 'https://en.wikipedia.org/wiki/List_of_DNS_record_types#AAAA' },
        'PTR': { full: 'Pointer record for reverse DNS lookup', url: 'https://en.wikipedia.org/wiki/List_of_DNS_record_types#PTR' },
        'BIND': { full: 'Berkeley Internet Name Domain', url: 'https://www.isc.org/bind/' },
        'CoreDNS': { full: 'Plugin-based DNS server used by Kubernetes', url: 'https://coredns.io/' },
        'Consul': { full: 'Service networking and discovery platform by HashiCorp', url: 'https://developer.hashicorp.com/consul' },
        'DNS': { full: 'Domain Name System', url: 'https://en.wikipedia.org/wiki/Domain_Name_System' },
        'CNAME': { full: 'Canonical Name Record (DNS)', url: 'https://en.wikipedia.org/wiki/CNAME_record' },
        'SRV': { full: 'Service Record (DNS)', url: 'https://en.wikipedia.org/wiki/SRV_record' },
      };

      const STORAGE_KEY = 'glossary-enabled';
      const toggle = document.querySelector('[data-glossary-toggle]');
      const content = document.querySelector('.post-content');
      if (!toggle || !content) return;

      let annotated = false;
      let fnCounter = 0;
      const seen = new Set();
      const footnotes = [];

      const annotateGlossary = () => {
        if (annotated) return;
        const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, {
          acceptNode: (node) => {
            const p = node.parentElement;
            if (!p) return NodeFilter.FILTER_REJECT;
            if (p.closest('[data-tts-skip], .glossary-ref, code, pre, a, sup')) return NodeFilter.FILTER_REJECT;
            if (p.tagName === 'SCRIPT' || p.tagName === 'STYLE') return NodeFilter.FILTER_REJECT;
            return NodeFilter.FILTER_ACCEPT;
          }
        });

        const textNodes = [];
        while (walker.nextNode()) textNodes.push(walker.currentNode);

        for (const node of textNodes) {
          const text = node.textContent;
          let matches = [];
           for (const [acronym, entry] of Object.entries(GLOSSARY)) {
             const escaped = acronym.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
             const re = new RegExp(`\\b${escaped}\\b`, 'g');
             let m;
             while ((m = re.exec(text)) !== null) {
               matches.push({ idx: m.index, len: acronym.length, acronym, entry });
             }
           }
          if (!matches.length) continue;
          matches.sort((a, b) => (a.idx - b.idx) || (b.len - a.len));

          const frag = document.createDocumentFragment();
          let lastIdx = 0;
          for (const { idx, len, acronym, entry } of matches) {
            if (idx < lastIdx) continue;
            if (idx > lastIdx) frag.appendChild(document.createTextNode(text.slice(lastIdx, idx)));
            frag.appendChild(document.createTextNode(acronym));

            const fnIdx = seen.has(acronym) ? footnotes.findIndex(f => f.acronym === acronym) + 1 : (() => {
              fnCounter++;
              seen.add(acronym);
              footnotes.push({ acronym, ...entry, num: fnCounter });
              return fnCounter;
            })();

            const sup = document.createElement('sup');
            sup.className = 'glossary-ref';
            sup.dataset.fn = fnIdx;
            sup.title = entry.full;
            sup.textContent = fnIdx;
            frag.appendChild(sup);

            lastIdx = idx + len;
          }
          if (lastIdx < text.length) frag.appendChild(document.createTextNode(text.slice(lastIdx)));
          node.parentNode.replaceChild(frag, node);
        }

        buildFootnotesSection();
        annotated = true;
      };

      const buildFootnotesSection = () => {
        if (!footnotes.length) return;
        const existing = content.querySelector('.post-footnotes');
        if (existing) existing.remove();

        const section = document.createElement('section');
        section.className = 'post-footnotes';
        section.setAttribute('data-tts-skip', '');
        const h = document.createElement('h4');
        h.textContent = 'Glossary & Footnotes';
        section.appendChild(h);

        footnotes.forEach(({ acronym, full, url, num }) => {
          const p = document.createElement('p');
          p.id = `glossary-footnote-${num}`;
          const sup = document.createElement('sup');
          sup.textContent = num;
          p.appendChild(sup);
          p.appendChild(document.createTextNode(' '));
          const strong = document.createElement('strong');
          strong.textContent = acronym;
          p.appendChild(strong);
          p.appendChild(document.createTextNode(` \u2014 ${full}. `));
          const a = document.createElement('a');
          a.href = url;
          a.target = '_blank';
          a.rel = 'noopener';
          a.textContent = 'link';
          p.appendChild(a);
          const back = document.createElement('a');
          back.href = '#';
          back.className = 'glossary-back';
          back.dataset.fn = num;
          back.title = 'Back to text';
          back.textContent = '\u21A9';
          p.appendChild(back);
          section.appendChild(p);
        });
        content.appendChild(section);
      };

      const applyState = (on) => {
        toggle.classList.toggle('active', on);
        toggle.setAttribute('aria-pressed', String(on));
        if (on) {
          annotateGlossary();
          content.classList.add('glossary-on');
        } else {
          content.classList.remove('glossary-on');
        }
      };

toggle.addEventListener('click', (e) => {
          e.preventDefault();
          const nowOn = !toggle.classList.contains('active');
          try { localStorage.setItem(STORAGE_KEY, String(nowOn)); } catch (_e) {}
          applyState(nowOn);
        });

      content.addEventListener('click', (e) => {
        const target = e.target;
        if (target.classList.contains('glossary-ref')) {
          e.preventDefault();
          const num = target.dataset.fn;
          const footnote = content.querySelector(`#glossary-footnote-${num}`);
          if (footnote) footnote.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else if (target.classList.contains('glossary-back')) {
          e.preventDefault();
          const num = target.dataset.fn;
          const ref = content.querySelector(`.glossary-ref[data-fn="${num}"]`);
          if (ref) ref.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });

      let savedOn = false;
      try { savedOn = localStorage.getItem(STORAGE_KEY) === 'true'; } catch (_e) {}
      applyState(savedOn);
    })();
  </script>
